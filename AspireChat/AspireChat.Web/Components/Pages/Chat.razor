@page "/chat/{groupId:int}/{groupName}"
@using AspireChat.Common.Chats
@using MudX
@attribute [Authorize]
@inject Clients.ChatClient ChatClient
@inject ILogger<Chat> Logger
@inject Services.IChatHubService ChatHubService
@inject AuthenticationStateProvider AuthProviderBase
@implements IAsyncDisposable

<MudPaper Class="pa-6" Elevation="0">
    <MudText Typo="Typo.h5" Class="mb-2">Chat: @GroupName</MudText>
    <MudDivider/>
    <MudStack Spacing="2" Class="overflow-y-auto flex-grow-1" Style="min-height:0;">
        @if (!_chats.Any())
        {
            <MudText>No messages yet.</MudText>
        }
        else
        {
            foreach (var chatGroup in GetChatGroups())
            {
                <MudXChat ChatPosition="@(chatGroup.IsMe ? ChatBubblePosition.End : ChatBubblePosition.Start)"
                          Dense="false"
                          Elevation="0"
                          Variant="Variant.Filled"
                          ArrowPosition="ChatArrowPosition.Top">
                    <MudXChatHeader Name="@chatGroup.Name"/>
                    <MudAvatar>
                        @if (string.IsNullOrEmpty(chatGroup.UserAvatarUrl))
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Person"/>
                        }
                        else
                        {
                            <MudImage Src="@chatGroup.UserAvatarUrl"/>
                        }
                    </MudAvatar>
                    @foreach (var message in chatGroup.Messages)
                    {
                        <MudXChatBubble>
                            <div>@message</div>
                        </MudXChatBubble>
                    }
                    <MudXChatFooter Text="@GetFooterText(chatGroup.Messages.Count)" />
                </MudXChat>
            }
        }
    </MudStack>
    <MudDivider Class="mt-2 mb-2"/>
    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
        <MudTextField @bind-Value="_newMessage"
                      Placeholder="Type a message..."
                      Variant="Variant.Outlined"
                      Class="flex-grow-1"
                      Adornment="Adornment.End"
                      AdornmentIcon="@Icons.Material.Filled.Send"
                      OnAdornmentClick="SendMessage"
                      Disabled="@_isSending"
                      OnKeyDown="HandleKeyDown"
                      DebounceInterval="1"/>
    </MudStack>
</MudPaper>

@code {
    [Parameter] public int GroupId { get; set; }

    [Parameter] public string GroupName { get; set; } = string.Empty;

    private List<GetAll.Dto> _chats = [];
    private string _newMessage = "";
    private bool _isSending;
    private int _myUserId;

    private Services.AuthProvider AuthProvider => (Services.AuthProvider)AuthProviderBase;

    protected override async Task OnInitializedAsync()
    {
        // Determine my user id first so we can compute IsMe correctly for both history and live messages
        _myUserId = await AuthProvider.GetUserIdAsync() ?? 0;

        await LoadChatsAsync();
        await ConnectSignalRAsync();
    }

    private async Task ConnectSignalRAsync()
    {
        try
        {
            // Refresh user id in case it changed
            _myUserId = await AuthProvider.GetUserIdAsync() ?? _myUserId;

            await ChatHubService.ConnectAsync(GroupId, async dto =>
            {
                dto.IsMe = dto.UserId == _myUserId;
                _chats.Add(dto);
                await InvokeAsync(StateHasChanged);
            });
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to connect to chat hub");
        }
    }

    private async Task LoadChatsAsync()
    {
        try
        {
            var result = await ChatClient.GetAllChatsAsync(GroupId, CancellationToken.None);
            _chats = result
                .Select(dto => { dto.IsMe = dto.UserId == _myUserId; return dto; })
                .ToList();
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load chats");
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(_newMessage)) return;
        _isSending = true;
        try
        {
            await ChatClient.SendMessageAsync(GroupId, _newMessage, CancellationToken.None);
            _newMessage = "";
            // No need to reload; SignalR will push the message
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to send message");
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !_isSending && !string.IsNullOrWhiteSpace(_newMessage))
        {
            await SendMessage();
        }
    }

    private IReadOnlyList<ChatGroup> GetChatGroups()
    {
        var groups = new List<ChatGroup>();
        ChatGroup? current = null;

        foreach (var chat in _chats.OrderBy(c => c.Id))
        {
            if (current is null || current.UserId != chat.UserId)
            {
                current = new ChatGroup
                {
                    UserId = chat.UserId,
                    Name = chat.Name,
                    UserAvatarUrl = chat.UserAvatarUrl,
                    IsMe = chat.IsMe,
                    Messages = [chat.Message]
                };

                groups.Add(current);
                continue;
            }

            current.Messages.Add(chat.Message);

            if (string.IsNullOrWhiteSpace(current.UserAvatarUrl) && !string.IsNullOrWhiteSpace(chat.UserAvatarUrl))
            {
                current.UserAvatarUrl = chat.UserAvatarUrl;
            }
        }

        return groups;
    }

    private static string GetFooterText(int messageCount)
        => messageCount == 1 ? "1 message" : $"{messageCount} messages";

    public async ValueTask DisposeAsync()
    {
        try
        {
            await ChatHubService.DisconnectAsync(GroupId);
        }
        catch(Exception ex)
        {
            Logger.LogError(ex, "Failed to send message");
        }
    }

    private sealed class ChatGroup
    {
        public int UserId { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? UserAvatarUrl { get; set; }
        public bool IsMe { get; set; }
        public List<string> Messages { get; set; } = [];
    }
}
